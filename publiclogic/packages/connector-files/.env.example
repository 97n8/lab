# connector-files — env config ONLY. Never commit real values.
#
# The Files/Drive surface to read. This is an MCP Files server's HTTP bridge or
# an official Files/Drive listing endpoint that returns JSON file records.
# (No scraping — the adapter reads exactly this configured endpoint.)
PJ_FILES_SOURCE_URL=

# Optional bearer token for the surface. Keep it in your environment / secret
# store — it must never be hardcoded or committed.
PJ_FILES_TOKEN=
